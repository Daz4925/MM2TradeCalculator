task.spawn(function()
	while true do
		local trade = getTrade()
		if trade then
			for _, offer in ipairs({trade:FindFirstChild("YourOffer"), trade:FindFirstChild("TheirOffer")}) do
				if offer and offer:FindFirstChild("Container") then
					for _, slot in ipairs(offer.Container:GetChildren()) do
						if slot:IsA("Frame") and slot.Visible then
							local name = getItemName(slot)
							local value = 0
							if name then
								if isChroma(slot) then name = "Chroma " .. name end
								value = (ItemValues[name] or 0) * getQty(slot)
							end
							local tag = slot:FindFirstChild("V7Tag")
							if value > 0 then
								if not tag then
									tag = Instance.new("TextLabel")
									tag.Name = "V7Tag"
									tag.Size = UDim2.new(0, 56, 0, 17)
									tag.Position = UDim2.new(0, 2, 0, 2)
									tag.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
									tag.BackgroundTransparency = 0.38
									tag.TextColor3 = Color3.fromRGB(70, 255, 140)
									tag.TextSize = 12
									tag.Font = Enum.Font.GothamBold
									tag.BorderSizePixel = 0
									tag.ZIndex = 999999
									tag.Parent = slot
									Instance.new("UICorner", tag).CornerRadius = UDim.new(0, 3)
								end
								tag.Text = abbrev(value)
							else
								if tag then tag:Destroy() end
							end
						end
					end
				end
			end
		end
		task.wait(0.1)
	end
end)


local function rebuildScroll(scroll, sideData)
	-- Destroy old rows only
	for _, ch in ipairs(scroll:GetChildren()) do
		if ch:IsA("Frame") then ch:Destroy() end
	end
	-- Sort: active first, then removed; alphabetical within each group
	local list = {}
	for _, entry in pairs(sideData) do
		table.insert(list, entry)
	end
	table.sort(list, function(a, b)
		if a.active ~= b.active then return a.active end  -- active first
		return a.name < b.name
	end)
	for i, entry in ipairs(list) do
		makeRow(scroll, entry, i)
	end
	scroll.CanvasSize = UDim2.new(0, 0, 0, #list * (ROW_H+1))
end

------------------------------------------------
-- HASHING (skip redraw when nothing changed)
------------------------------------------------

local function sideHash(sideData)
	local parts = {}
	for k, v in pairs(sideData) do
		table.insert(parts, k .. v.qty .. tostring(v.active))
	end
	table.sort(parts)
	return table.concat(parts, "|")
end

local lastYourHash  = ""
local lastTheirHash = ""

------------------------------------------------
-- MAIN UPDATE
------------------------------------------------

local function update()
	local trade = getTrade()

	if not trade then
		-- Trade closed — reset ghost tracking for next session
		if tradeActive then
			tradeActive = false
			resetSeen()
			lastYourHash  = ""
			lastTheirHash = ""
			rebuildScroll(yourScroll,  seenItems.your)
			rebuildScroll(theirScroll, seenItems.their)
			yourTotVal.Text  = "0"
			theirTotVal.Text = "0"
			diffLbl.Text = "DIFF: —"
			diffLbl.TextColor3 = Color3.fromRGB(150, 150, 185)
			badge.Text = "NO TRADE"
			badge.BackgroundColor3 = Color3.fromRGB(55, 55, 70)
			badge.TextColor3 = Color3.fromRGB(160, 160, 185)
			if traderLbl then traderLbl.Text = "👤 Waiting for trade..." end
			trackBadge.Visible = false
		end
		return
	end

	tradeActive = true
	local theirOffer = trade:FindFirstChild("TheirOffer")
	local yourOffer  = trade:FindFirstChild("YourOffer")
	local matched    = usernameMatches(theirOffer)

	-- Update trader label
	if traderLbl then
		if matched then
			local displayName = getTraderDisplayName(theirOffer) or "Garuda_Storage0001"
			traderLbl.Text = "👤 " .. displayName .. "  ✓ TRACKED"
			traderLbl.TextColor3 = Color3.fromRGB(80, 220, 130)
			trackBadge.Text = "  🟢 TRACKING ACTIVE"
			trackBadge.Visible = true
		else
			local fallback = nil
			if theirOffer then
				for _, obj in ipairs(theirOffer:GetDescendants()) do
					if obj:IsA("TextLabel") and obj.Text ~= "" then
						local t = obj.Text
						if t:match("^%(") and #t >= 4 and #t <= 24 then
							fallback = t:match("%((.-)%)") or t
							break
						end
					end
				end
			end
			traderLbl.Text = fallback and ("👤 " .. fallback) or "👤 In trade..."
			traderLbl.TextColor3 = Color3.fromRGB(130, 170, 255)
			trackBadge.Visible = false
		end
	end

	-- Read live items for both sides
	local liveYour  = readLiveItems(yourOffer)
	local liveTheir = readLiveItems(theirOffer)

	-- Merge into ghost tracker
	mergeIntoSeen("your",  liveYour)
	-- Only ghost-track THEIR side when username matches
	if matched then
		mergeIntoSeen("their", liveTheir)
	else
		-- Without match: just show live items, no ghosts
		seenItems.their = {}
		for k, v in pairs(liveTheir) do
			seenItems.their[k] = {name=v.name, qty=v.qty, value=v.value, active=true}
		end
	end

	-- Rebuild tables only when something changed
	local yh = sideHash(seenItems.your)
	local th = sideHash(seenItems.their)

	if yh ~= lastYourHash then
		lastYourHash = yh
		rebuildScroll(yourScroll, seenItems.your)
		-- Total = only active items
		local tot = 0
		for _, e in pairs(seenItems.your) do if e.active then tot += e.value end end
		yourTotVal.Text = abbrev(tot)
	end

	if th ~= lastTheirHash then
		lastTheirHash = th
		rebuildScroll(theirScroll, seenItems.their)
		local tot = 0
		for _, e in pairs(seenItems.their) do if e.active then tot += e.value end end
		theirTotVal.Text = abbrev(tot)
	end

	-- Status bar
	local yourVal, theirVal = 0, 0
	for _, e in pairs(seenItems.your)  do if e.active then yourVal  += e.value end end
	for _, e in pairs(seenItems.their) do if e.active then theirVal += e.value end end
	local diff = theirVal - yourVal

	diffLbl.Text = string.format("DIFF: %s%s", diff >= 0 and "+" or "", abbrev(diff))

	if yourVal == 0 and theirVal == 0 then
		badge.Text = "WAITING"
		badge.BackgroundColor3 = Color3.fromRGB(50, 50, 65)
		badge.TextColor3 = Color3.fromRGB(150, 150, 180)
		diffLbl.TextColor3 = Color3.fromRGB(150, 150, 185)
	elseif yourVal == theirVal then
		badge.Text = "FAIR"
		badge.BackgroundColor3 = Color3.fromRGB(45, 130, 50)
		badge.TextColor3 = Color3.fromRGB(170, 255, 170)
		diffLbl.TextColor3 = Color3.fromRGB(170, 255, 170)
	elseif theirVal > yourVal then
		badge.Text = "WIN ▲"
		badge.BackgroundColor3 = Color3.fromRGB(28, 95, 175)
		badge.TextColor3 = Color3.fromRGB(140, 205, 255)
		diffLbl.TextColor3 = Color3.fromRGB(140, 205, 255)
	else
		badge.Text = "LOSS ▼"
		badge.BackgroundColor3 = Color3.fromRGB(155, 38, 38)
		badge.TextColor3 = Color3.fromRGB(255, 145, 145)
		diffLbl.TextColor3 = Color3.fromRGB(255, 145, 145)
	end
end


-- HELPERS
------------------------------------------------

local function abbrev(n)
	if n >= 1000000 then return string.format("%.1fM", n/1000000)
	elseif n >= 1000 then return string.format("%.1fK", n/1000)
	else return tostring(n) end
end

local function getTrade()
	local tradeGui = playerGui:FindFirstChild("TradeGUI")
	if not tradeGui then return nil end
	local container = tradeGui:FindFirstChild("Container")
	if not container then return nil end
	return container:FindFirstChild("Trade")
end

-- Reads the item name from a trade slot
local function getItemName(slot)
	local obj = slot:FindFirstChild("ItemName", true)
	if not obj then return nil end
	local label = obj:FindFirstChild("Label")
	if label and label:IsA("TextLabel") then
		return label.Text ~= "" and label.Text or nil
	elseif obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox") then
		return obj.Text ~= "" and obj.Text or nil
	end
	return nil
end

local function isChroma(slot)
	local tags = slot:FindFirstChild("Tags", true)
	if tags then
		local c = tags:FindFirstChild("Chroma")
		if c and c:IsA("GuiObject") and c.Visible then return true end
	end
	return false
end

local function getQty(slot)
	local obj = slot:FindFirstChild("Amount", true)
	if obj and (obj:IsA("TextLabel") or obj:IsA("TextButton") or obj:IsA("TextBox")) then
		local n = tostring(obj.Text or ""):match("%d+")
		if n then local v = tonumber(n); if v and v > 0 then return v end end
	end
	return 1
end

------------------------------------------------
-- USERNAME MATCH (exact method from your gated script)
-- MM2 wraps names as "(Username)" inside TheirOffer
------------------------------------------------

local TARGET_USERNAME = "(Garuda_Storage0001)"

local function usernameMatches(theirOffer)
	if not theirOffer then return false end
	for _, obj in ipairs(theirOffer:GetDescendants()) do
		if obj:IsA("TextLabel") and obj.Text == TARGET_USERNAME then
			return true
		end
	end
	return false
end

-- Extract clean display name from parenthesised match
local function getTraderDisplayName(theirOffer)
	if not theirOffer then return nil end
	for _, obj in ipairs(theirOffer:GetDescendants()) do
		if obj:IsA("TextLabel") and obj.Text == TARGET_USERNAME then
			-- strip parentheses for display
			return obj.Text:match("%((.-)%)") or obj.Text
		end
	end
	return nil
end

------------------------------------------------
-- READ LIVE ITEMS FROM AN OFFER SIDE
-- Returns: { [itemKey] = {name, qty, value} }
------------------------------------------------

local function readLiveItems(offer)
	local result = {}
	if not offer then return result end
	local container = offer:FindFirstChild("Container")
	if not container then return result end
	for _, slot in ipairs(container:GetChildren()) do
		if slot:IsA("Frame") and slot.Visible then
			local name = getItemName(slot)
			if name and name ~= "" then
				if isChroma(slot) then name = "Chroma " .. name end
				local qty = getQty(slot)
				local val = (ItemValues[name] or 0) * qty
				if val > 0 then
					local key = name -- one slot per unique name (MM2 stacks dupes)
					if result[key] then
						result[key].qty = result[key].qty + qty
						result[key].value = result[key].value + val
					else
						result[key] = {name = name, qty = qty, value = val}
					end
				end
			end
		end
	end
	return result
end

local function sumTable(t)
	local total = 0
	for _, v in pairs(t) do total += v.value end
	return total
end

------------------------------------------------
-- GHOST ITEM TRACKER
-- seenItems[side][key] = {name, qty, value, active}
-- active=true  → currently in trade (shown normally)
-- active=false → was removed (shown as ghost/strikethrough)
------------------------------------------------

local seenItems = { your = {}, their = {} }
local tradeActive = false  -- reset ghosts when trade window closes

local function mergeIntoSeen(side, liveItems)
	-- mark all existing as inactive first
	for key, entry in pairs(seenItems[side]) do
		entry.active = false
	end
	-- layer live items back in
	for key, live in pairs(liveItems) do
		if seenItems[side][key] then
			seenItems[side][key].qty   = live.qty
			seenItems[side][key].value = live.value
			seenItems[side][key].active = true
		else
			seenItems[side][key] = {
				name   = live.name,
				qty    = live.qty,
				value  = live.value,
				active = true,
			}
		end
	end
end

local function resetSeen()
	seenItems = { your = {}, their = {} }
end

